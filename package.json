{
  "name": "multiagent-framework",
  "version": "0.1.0",
  "description": "Config-driven multi-agent orchestration framework powered by the Claude API",
  "type": "module",
  "bin": {
    "magent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "run": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^3.2.6"
  }
}
